# ── docker-compose variable substitution ─────────────────────────────────────
# This file is read by docker-compose itself for variable expansion in
# docker-compose.yml (volume paths, port mappings).
# All application secrets and service config belong in backend/.env.

# Path to the SFTP private key on the HOST machine.
# It is bind-mounted read-only into the backend and worker containers.
SFTP_KEY_FILE=~/.ssh/id_rsa

# Ports exposed on the host
BACKEND_PORT=8000
REDIS_PORT=6379
