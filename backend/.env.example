# ── SoundCloud ────────────────────────────────────────────────────────────────
SC_CLIENT_ID=
SC_OAUTH_TOKEN=

# Path to a Netscape cookie jar for SoundCloud downloads.
# Export from your browser with the "Get cookies.txt LOCALLY" extension.
# When set, this overrides the --cookies path in config/yt-dlp.conf.
# If not set, /app/config/cookies.txt is used (the default in yt-dlp.conf).
SC_COOKIES_FILE=

# ── YouTube ───────────────────────────────────────────────────────────────────
# Path to a Netscape cookie jar for YouTube / YouTube Music downloads.
# Required for private or age-restricted videos, and recommended for VPS use.
# Export from your browser with the "Get cookies.txt LOCALLY" extension
# and mount the file into the container (e.g. ./config/yt-cookies.txt).
YOUTUBE_COOKIES_FILE=

# ── SFTP ──────────────────────────────────────────────────────────────────────
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_KEY_FILE=~/.ssh/id_rsa
SFTP_PASSWORD=
SFTP_BASE=/home/user/music

# ── Navidrome ─────────────────────────────────────────────────────────────────
NAVIDROME_URL=http://localhost:4533
NAVIDROME_ADMIN_USER=admin
NAVIDROME_ADMIN_PASSWORD=

# ── Telegram bot ──────────────────────────────────────────────────────────────
BOT_TOKEN=
ADMIN_USER_TELEGRAM_ID=

# ── Bot database ──────────────────────────────────────────────────────────────
# Path to SQLite database file (default: metamusic.db in working directory)
DB_PATH=metamusic.db

# ── Backend server ────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Proxy ─────────────────────────────────────────────────────────────────────
# Route yt-dlp/downloads through a proxy (e.g. local SSH SOCKS5 tunnel).
# Leave empty to disable.
YTDLP_PROXY=
