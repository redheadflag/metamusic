# ── SFTP connection ───────────────────────────────────────────────────────────
SFTP_HOST=192.168.1.100
SFTP_PORT=22
SFTP_USER=myuser

# Prefer key-based auth:
SFTP_KEY_FILE=/home/me/.ssh/id_ed25519
# Password fallback (leave blank if using a key):
# SFTP_PASSWORD=

# Base folder on the remote machine.
# Input  (raw files from backend) : <SFTP_BASE>/unprocessed/
# Output (processed files)        : <SFTP_BASE>/
SFTP_BASE=/home/myuser/music

# ── FFmpeg options ────────────────────────────────────────────────────────────
FFMPEG_CODEC=libmp3lame
FFMPEG_EXT=.mp3
FFMPEG_MAX_BITRATE_KBPS=256

# ── Behaviour ─────────────────────────────────────────────────────────────────
# How often (seconds) to poll the input folder for new files.
POLL_INTERVAL_SECONDS=30
# Remove the raw source file after a successful conversion + upload.
DELETE_SOURCE_AFTER_PROCESSING=true
# Number of files to convert in parallel.
WORKER_THREADS=2
